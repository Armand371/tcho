# Copy to .env.local and fill in. Values are validated in src/env.ts.
# .env.local is git-ignored — never commit real secrets.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Auth.js v5 / Google) ---

# Signs the session JWT. Generate with:  npx auth secret
AUTH_SECRET=

# Google OAuth 2.0 Web client credentials.
# Create one at: https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
#     (add the production URL there too once deployed)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google Workspace domain allowed to sign in (e.g. example.com).
ALLOWED_GOOGLE_DOMAIN=

# Break-glass allowlist: comma-separated emails allowed regardless of domain.
# Optional — leave blank for none. Example: alice@gmail.com,bob@example.org
ADMIN_EMAILS=

# Canonical deployment URL. Optional in dev; set in production behind a proxy.
# AUTH_URL=https://portal.example.com
